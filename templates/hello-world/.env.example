# Sovrium environment variables — this template
# Copy to .env and uncomment what you need. Every variable is OPTIONAL:
# `sovrium start app.yaml` runs zero-config with embedded SQLite and local
# file storage.

# ── Core ──────────────────────────────────────────────────────────────
# PORT=3000
# BASE_URL=http://localhost:3000
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname   # omit → SQLite
