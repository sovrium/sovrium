    "hono": "^4.12.22",
    "lucide-react": "^1.16.0",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "nodemailer": "^8.0.7",
    "ollama": "^0.6.3",
    "openai": "^6.39.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
