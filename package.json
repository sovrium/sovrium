{
  "name": "sovrium",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "Configuration-driven web application platform — distributed as standalone binary",
  "author": {
    "name": "Thomas Jeanneau",
    "company": "ESSENTIAL SERVICES",
    "email": "support@sovrium.com"
  },
  "license": "BUSL-1.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovrium/sovrium.git"
  },
  "bugs": {
    "url": "https://github.com/sovrium/sovrium/issues"
  },
  "homepage": "https://sovrium.com",
  "keywords": [
    "sovrium",
    "bun",
    "typescript",
    "framework",
    "configuration",
    "self-hosted"
  ],
  "files": [
    "dist/**/*.js",
    "agents/**",
    "examples/**"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "effect-language-service patch > /dev/null 2>&1",
    "build": "bun run scripts/build/build.ts",
    "build:binary": "bun run scripts/build/build-binary.ts",
    "build:css-assets": "bun run scripts/build/generate-css-assets.ts",
    "build:types": "bun run scripts/build/build-types.ts",
    "start": "bun run src/cli/index.ts --watch",
    "format": "prettier --write . --cache --cache-location .prettiercache",
    "format:check": "prettier --check . --cache --cache-location .prettiercache",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=12288 tsc --noEmit",
    "clean": "knip",
    "clean:fix": "knip --fix",
    "lint": "NODE_OPTIONS=--max-old-space-size=12288 eslint . --cache --cache-location .eslintcache --cache-strategy content",
    "lint:fix": "NODE_OPTIONS=--max-old-space-size=12288 eslint . --fix --cache --cache-location .eslintcache --cache-strategy content",
    "lint:workflows": "actionlint",
    "audit": "bun audit",
    "quality": "bun run scripts/check-quality.ts",
    "test:unit": "bun test .test.ts .test.tsx",
    "test:unit:concurrent": "bun test --concurrent .test.ts .test.tsx",
    "test:e2e": "playwright test",
    "test:e2e:spec": "playwright test --grep='@spec'",
    "test:e2e:regression": "playwright test --grep='@regression'",
    "test:e2e:packaging": "playwright test --grep='@packaging'",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:update-snapshots:spec": "playwright test --grep='@spec' --update-snapshots",
    "test:e2e:update-snapshots:regression": "playwright test --grep='@regression' --update-snapshots",
    "test:e2e:snapshots:docker": "bun run scripts/snapshots-docker.ts",
    "test:all": "bun test:unit && bun test:e2e:regression",
    "test:cleanup": "bun run scripts/kill-zombie-processes.ts",
    "license": "bun run scripts/add-license-headers.ts",
    "progress": "bun run scripts/check-progress.ts",
    "check:all": "bun run quality && bun run progress --strict",
    "db:generate": "drizzle-kit generate && bun run scripts/postprocess-drizzle-migrations.ts",
    "db:generate:sqlite": "bun run scripts/generate-sqlite-migrations.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "db:check": "drizzle-kit check",
    "analyze-commits": "bun run scripts/analyze-commits.ts",
    "release": "bun run scripts/release.ts"
  },
  "overrides": {
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "0.85.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/oxide": "^4.3.0",
    "@tanstack/react-query-devtools": "5.100.9",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-functional": "^9.0.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "64.0.0",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "otplib": "^13.4.0",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "testcontainers": "^11.14.0",
    "typescript-eslint": "^8.59.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.3 || ^6.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.96.0",
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/s3-request-presigner": "^3.1052.0",
    "@base-ui/react": "^1.5.0",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@better-auth/oauth-provider": "^1.6.11",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@effect/experimental": "^0.60.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@google/generative-ai": "^0.24.1",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.4.0",
    "@mistralai/mistralai": "2.2.1",
    "@react-pdf/renderer": "^4.5.1",
    "@scalar/hono-api-reference": "^0.10.18",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-table": "8.21.3",
    "@tiptap/extension-character-count": "^3.23.6",
    "@tiptap/extension-code-block-lowlight": "^3.23.6",
