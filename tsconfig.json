{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    // MUST stay false. The generated `embedded-runtime-assets.generated.ts`
    // asset-imports ~470 pre-built `dist/island-chunks/*.js` bundles via
    // `import _r from '../../../dist/*.js' with { type: 'file' }` (opaque file
    // handles consumed by Bun's bundler, never as typed modules). With
    // `allowJs: true`, tsc resolved those bundled JS artifacts INTO the program
    // (relative imports bypass `exclude`) and tried to infer + serialize their
    // deeply-nested type graphs for the incremental `.tsbuildinfo` /
    // declaration emit — overflowing the call stack
    // (`serializeTypeForDeclaration` → RangeError) whenever `dist/` was present
    // on disk. No `.ts`/`.tsx` source depends on JS type-checking, and the only
    // plain `.js` files in src/ (presentation/scripts/client/*.js) are
    // standalone browser scripts that are never module-imported, so disabling
    // JS parsing is purely correct here. Also protects the release
    // declaration-emit build (tsconfig.build.json), which inherits this and
    // would crash identically. See the "no dist → clean / with dist → crash"
    // bisection. DO NOT flip back to true.
    "allowJs": false,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Incremental type checking — persist the dependency graph to a fixed,
    // gitignored cache so warm `typecheck`/`quality` runs only re-check changed
    // files. node_modules is already gitignored, so the cache survives cleans.
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsc/tsconfig.tsbuildinfo",

    // Explicit type declarations (required in TS 6 — types defaults to [])
    "types": ["bun", "node", "react-dom", "nodemailer", "pg"],

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (enabled for code quality)
    "noUnusedLocals": true,
    "noUnusedParameters": false, // Disabled to allow incomplete test stubs in specs/
    "noPropertyAccessFromIndexSignature": false,

    // Path aliases (baseUrl deprecated in TS 7, silence for now)
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/specs/*": ["specs/*"],
      "@apps/*": ["apps/*"],
      // Resolve the workspace package to its source instead of the built
      // dist/ output. dist/ is a gitignored build artifact (only produced by
      // `bun run build:types`), so without this mapping a clean checkout fails
      // typecheck with TS2307 the moment anything in the program imports
      // @sovrium/types — e.g. the apps/* configs. Points at source, matching
      // the @apps/* / @/* source-alias pattern above.
      "@sovrium/types": ["packages/types/src/index.ts"]
    },

    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  // Bound the typecheck program to the three source roots only. Without an
  // explicit `include`, tsc defaults to "every .ts under the project root minus
  // exclude", silently pulling in stray files (examples/, packages/types — which
  // has its own tsconfig + build:types). Dependents that override `include`
  // (tsconfig.build.json → ["src"], tsconfig.eslint.json → []) are unaffected.
  "include": ["src", "specs", "scripts", "apps"],
  "exclude": ["node_modules", "dist", "tmp", "vendor", "docs"]
}
